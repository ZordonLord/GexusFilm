<?xml version="1.0"?>
<ruleset name="GexusFilm Backend">
    <description>PHP CodeSniffer rules for GexusFilm backend</description>

    <file>src</file>
    <file>public</file>
    <file>tests</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>

    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg name="parallel" value="75"/>
    <arg value="np"/>

    <rule ref="PSR12"/>
</ruleset>
